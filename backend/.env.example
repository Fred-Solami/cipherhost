# CipherHost Controller Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/cipherhost.db

# Port Range for Deployed Applications
PORT_RANGE_MIN=5000
PORT_RANGE_MAX=6000

# Security
# IMPORTANT: Change these in production!
# The API_KEY must match the VITE_API_KEY in frontend/.env
# Only users with this key can access the API
JWT_SECRET=your-secret-key-change-in-production
API_KEY=your-api-key-change-in-production

# PM2 Configuration
PM2_HOME=C:/CipherHost/.pm2

# Caddy Configuration
CADDY_API_URL=http://localhost:2019
CADDY_CONFIG_PATH=C:/CipherHost/caddy/config.json

# Deployment Settings
APPS_BASE_DIR=C:/CipherHost/apps
MAX_AUTO_RESTARTS=5
HEALTH_CHECK_INTERVAL=30000

# NPM Security (DO NOT CHANGE)
DISABLE_NPM_SCRIPTS=true
REQUIRE_PACKAGE_LOCK=true

# Service Account (Windows)
SERVICE_ACCOUNT=CipherHostService
